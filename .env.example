# Site Configuration
SITE_URL=https://www.sarkaridarapan.info
NEXT_PUBLIC_SITE_URL=https://www.sarkaridarapan.info

# Google AdSense - Replace with your actual publisher ID
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# Google Analytics 4 - Replace with your measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Search Engine Verification Codes
# Google Search Console: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Bing Webmaster Tools: https://www.bing.com/webmasters
NEXT_PUBLIC_BING_VERIFICATION=your-bing-verification-code

# Yandex Webmaster: https://webmaster.yandex.com
NEXT_PUBLIC_YANDEX_VERIFICATION=your-yandex-verification-code

# IndexNow Key (for instant indexing on Bing/Yandex)
# Generate at: https://www.indexnow.org/
INDEXNOW_KEY=your-indexnow-key-here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Alerts (quality gate notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
